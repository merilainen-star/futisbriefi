# Copy to .env and fill in. NEVER commit .env.

# The Odds API (https://the-odds-api.com) — free tier, soccer 1X2 / h2h.
ODDS_API_KEY=

# Which odds provider to use: "theoddsapi" | "mock"
ODDS_PROVIDER=mock

# The Odds API sport key for the World Cup (set when the 2026 key is live).
# Examples seen historically: soccer_fifa_world_cup, soccer_fifa_world_cup_qualifiers
ODDS_SPORT_KEY=soccer_fifa_world_cup

# Regions/markets for The Odds API
ODDS_REGIONS=eu
ODDS_MARKETS=h2h

# FotMob client: "json" (x-mas signed) | "playwright"
FOTMOB_CLIENT=json

# Timezone for display + scheduling. Do not change without updating tests.
APP_TZ=Europe/Helsinki

# Local SQLite path
DB_PATH=./data/fm2026.db
